# Required — your FreshService subdomain (e.g. "acme" for acme.freshservice.com)
FRESHSERVICE_DOMAIN=your-domain

# Required — Base64-encoded "apikey:X" string, or plain API key depending on your setup
FRESHSERVICE_API_KEY=your-api-key

# Optional — custom field slugs (find them via GET /api/debug)
# Defaults shown below; only set these if your instance uses different names.
# FS_FIELD_START_DATE=start_date
# FS_FIELD_END_DATE=experiment_end_date

# Optional — ticket filters (defaults match the SaaS experimentation request type)
# FS_TICKET_TYPE=Service Request
# FS_SUBJECT_FILTER=Request SaaS Application for Experimentation
